// NSI Platform — Prisma Schema
// All IDs are UUID v4. No numeric IDs anywhere.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_URL")
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────

enum UserRole {
  USER
  CUSTOMER
  DISTRIBUTOR
  ADMIN
  SUPER_ADMIN
}

enum UserStatus {
  REGISTERED
  EMAIL_VERIFIED
  
  PROFILE_INCOMPLETE
  ACTIVE
  SUSPENDED
}

enum AuthProvider {
  EMAIL
  GOOGLE
}

// ─── Models ──────────────────────────────────────────

model User {
  uuid          String        @id @default(uuid())
  fullName      String
  email         String        @unique
  passwordHash  String?
  googleId      String?       @unique
  avatarUrl     String?       @map("avatar_url")
  authProvider  AuthProvider  @default(EMAIL)
  role          UserRole      @default(USER)
  status        UserStatus    @default(REGISTERED)
  emailVerified Boolean       @default(false)
  country       String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  suspendedAt    DateTime?     @map("suspended_at")
  suspendedBy    String?       @map("suspended_by")
  joinLinkActive Boolean       @default(true) @map("join_link_active")
  distributorCode String?      @unique @map("distributor_code")

  sessions  AuthSession[]
  otps      EmailOTP[]
  auditLogs AuditLog[]

  funnelProgress FunnelProgress?
  acquisition    UserAcquisition?
  profile        UserProfile?
  payments       Payment[]
  couponUses     CouponUse[]

  // Lead relations
  leadAsUser        Lead?          @relation("LeadUser")
  leadsAssigned     Lead[]         @relation("LeadAssignedTo")
  leadsDistributed  Lead[]         @relation("LeadDistributor")
  leadActivities    LeadActivity[]
  nurtureEnrollment NurtureEnrollment?

  // LMS relations
  enrollments    CourseEnrollment[]
  lessonProgress LessonProgress[]

  // Module 6: Distributor
  distributorSubscription        DistributorSubscription?
  distributorSubscriptionHistory DistributorSubscriptionHistory[] @relation("DistributorSubscriptionHistory")

  // Module 7: Tasks + Calendar
  distributorTasks         DistributorTask[]          @relation("DistributorTasks")
  distributorCalendarNotes DistributorCalendarNote[]  @relation("DistributorCalendarNotes")

  // Module 8: Campaigns
  campaigns Campaign[]

  @@map("users")
}

model AuthSession {
  uuid             String   @id @default(uuid())
  userUuid         String
  tokenId          String
  refreshTokenHash String
  expiresAt        DateTime
  ipAddress        String
  userAgent        String
  createdAt        DateTime @default(now())

  user User @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@index([userUuid])
  @@index([tokenId])
  @@map("auth_sessions")
}

model EmailOTP {
  uuid      String   @id @default(uuid())
  userUuid  String
  otpHash   String
  attempts  Int      @default(0)
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@index([userUuid])
  @@map("email_otps")
}

model AuditLog {
  uuid      String   @id @default(uuid())
  actorUuid String?
  action    String
  metadata  Json
  ipAddress String
  createdAt DateTime @default(now())

  actor User? @relation(fields: [actorUuid], references: [uuid], onDelete: SetNull)

  @@index([actorUuid])
  @@index([action])
  @@map("audit_logs")
}

// ─── Funnel Engine Enums ─────────────────────────────

enum StepType {
  VIDEO_TEXT
  PHONE_GATE
  PAYMENT_GATE
  DECISION
}

enum FunnelProgressStatus {
  IN_PROGRESS
  COMPLETED
  DROPPED
}

// ─── Funnel Engine Models ─────────────────────────────

model FunnelSection {
  uuid        String       @id @default(uuid())
  name        String
  description String?
  order       Int
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  steps       FunnelStep[]
  @@map("funnel_sections")
}

model FunnelStep {
  uuid        String   @id @default(uuid())
  sectionUuid String
  type        StepType
  order       Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  section      FunnelSection       @relation(fields: [sectionUuid], references: [uuid], onDelete: Cascade)
  content      StepContent?
  phoneGate    PhoneGateConfig?
  paymentGate  PaymentGateConfig?
  decisionStep DecisionStepConfig?
  progress     StepProgress[]

  @@index([sectionUuid])
  @@map("funnel_steps")
}

model StepContent {
  uuid                   String   @id @default(uuid())
  stepUuid               String   @unique
  title                  String
  description            String?
  videoUrl               String?
  bunnyVideoId           String?  @map("bunny_video_id")
  videoDuration          Int? // total seconds
  textContent            String? // stored as HTML
  requireVideoCompletion Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  step FunnelStep @relation(fields: [stepUuid], references: [uuid], onDelete: Cascade)

  @@map("step_content")
}

model PhoneGateConfig {
  uuid     String  @id @default(uuid())
  stepUuid String  @unique
  title    String  @default("Verify your phone number")
  subtitle String?
  isActive Boolean @default(true)

  step FunnelStep @relation(fields: [stepUuid], references: [uuid], onDelete: Cascade)

  @@map("phone_gate_configs")
}

model PaymentGateConfig {
  uuid         String  @id @default(uuid())
  stepUuid     String  @unique
  title         String   @default("Unlock content")
  subtitle      String?
  amount        Decimal
  currency      String   @default("INR")
  allowCoupons  Boolean  @default(true)
  isActive      Boolean  @default(true)
  badge         String?
  originalPrice Decimal?

  step FunnelStep @relation(fields: [stepUuid], references: [uuid], onDelete: Cascade)

  @@map("payment_gate_configs")
}

model DecisionStepConfig {
  uuid      String  @id @default(uuid())
  stepUuid  String  @unique
  question  String  @default("Are you interested in buying a Kangen machine?")
  yesLabel  String  @default("Yes, I am interested!")
  noLabel   String  @default("Not right now")
  yesSubtext String?
  noSubtext  String?

  step FunnelStep @relation(fields: [stepUuid], references: [uuid], onDelete: Cascade)

  @@map("decision_step_configs")
}

model FunnelProgress {
  uuid               String               @id @default(uuid())
  userUuid           String               @unique
  currentSectionUuid String?
  currentStepUuid    String?
  status             FunnelProgressStatus @default(IN_PROGRESS)
  phoneVerified      Boolean              @default(false)
  paymentCompleted   Boolean              @default(false)
  decisionAnswer     String?
  decisionAnsweredAt DateTime?
  lastSeenAt         DateTime             @default(now())
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  user         User           @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  stepProgress StepProgress[]

  @@map("funnel_progress")
}

model StepProgress {
  uuid               String    @id @default(uuid())
  funnelProgressUuid String
  stepUuid           String
  isCompleted        Boolean   @default(false)
  watchedSeconds     Int       @default(0)
  completedAt        DateTime?
  createdAt          DateTime  @default(now())

  funnelProgress FunnelProgress @relation(fields: [funnelProgressUuid], references: [uuid], onDelete: Cascade)
  step           FunnelStep     @relation(fields: [stepUuid], references: [uuid], onDelete: Cascade)

  @@unique([funnelProgressUuid, stepUuid])
  @@index([funnelProgressUuid])
  @@map("step_progress")
}

model UserAcquisition {
  uuid            String   @id @default(uuid())
  userUuid        String   @unique
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?
  utmContent      String?
  utmTerm         String?
  referrerUrl     String?
  landingPage     String?
  distributorCode String?
  distributorUuid String?
  ipAddress       String?
  country         String?
  city            String?
  deviceType      String?
  browser         String?
  capturedAt      DateTime @default(now())

  user User @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)

  @@map("user_acquisitions")
}

// ─── Module 3 Enums ──────────────────────────────────

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentType {
  COMMITMENT_FEE
  LMS_COURSE
  DISTRIBUTOR_SUB
}

enum CouponType {
  FLAT
  PERCENT
  FREE
}

enum CouponScope {
  COMMITMENT_FEE
  LMS_COURSE
  DISTRIBUTOR_SUB
  ALL
}

// ─── Module 3 Models ─────────────────────────────────

model UserProfile {
  uuid            String    @id @default(uuid())
  userUuid        String    @unique
  user            User      @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  phone           String    @unique
  phoneVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("user_profiles")
}

model Payment {
  uuid             String        @id @default(uuid())
  userUuid         String
  user             User          @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  gatewayOrderId   String?       @unique
  gatewayPaymentId String?       @unique
  invoiceNumber    String?       @unique
  invoiceUrl       String?
  amount           Int
  discountAmount   Int           @default(0)
  finalAmount      Int
  currency         String        @default("INR")
  status           PaymentStatus @default(PENDING)
  paymentType      PaymentType
  couponUuid       String?
  coupon           Coupon?       @relation(fields: [couponUuid], references: [uuid])
  metadata         Json?
  termsAcceptedAt   DateTime?   @map("terms_accepted_at")
  termsVersion      String?     @map("terms_version")
  termsAcceptedIp   String?     @map("terms_accepted_ip")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([userUuid])
  @@index([status, createdAt])
  @@index([userUuid, status])
  @@map("payments")
}

model Coupon {
  uuid         String      @id @default(uuid())
  code         String      @unique
  type         CouponType
  value        Int
  applicableTo CouponScope
  usageLimit   Int?
  usedCount    Int         @default(0)
  perUserLimit Int         @default(1)
  expiresAt    DateTime?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  uses     CouponUse[]
  payments Payment[]

  @@map("coupons")
}

model CouponUse {
  uuid       String   @id @default(uuid())
  couponUuid String
  coupon     Coupon   @relation(fields: [couponUuid], references: [uuid], onDelete: Cascade)
  userUuid   String
  user       User     @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  createdAt  DateTime @default(now())

  @@unique([couponUuid, userUuid])
  @@map("coupon_uses")
}

// ─── Module 4 Enums ──────────────────────────────────

enum LeadStatus {
  NEW
  WARM
  HOT
  CONTACTED
  FOLLOWUP
  NURTURE
  LOST
  MARK_AS_CUSTOMER
}

enum LeadAction {
  STATUS_CHANGE
  NOTE
  FOLLOWUP_SCHEDULED
}

enum NurtureStatus {
  ACTIVE
  COMPLETED
  UNSUBSCRIBED
}

// ─── Module 4 Models ─────────────────────────────────

model Lead {
  uuid            String      @id @default(uuid())
  userUuid        String      @unique
  assignedToUuid  String
  distributorUuid String?
  status          LeadStatus  @default(NEW)
  phone           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user              User              @relation("LeadUser", fields: [userUuid], references: [uuid])
  assignedTo        User              @relation("LeadAssignedTo", fields: [assignedToUuid], references: [uuid])
  distributor       User?             @relation("LeadDistributor", fields: [distributorUuid], references: [uuid])
  activities        LeadActivity[]
  nurtureEnrollment NurtureEnrollment?
  distributorTasks  DistributorTask[]
  statusLogs        LeadStatusLog[]

  @@index([assignedToUuid])
  @@index([distributorUuid])
  @@index([status])
  @@index([status, createdAt])
  @@map("leads")
}

model LeadActivity {
  uuid       String      @id @default(uuid())
  leadUuid   String
  actorUuid  String
  fromStatus LeadStatus?
  toStatus   LeadStatus?
  action     LeadAction
  notes      String?
  followupAt DateTime?
  createdAt  DateTime    @default(now())

  lead  Lead @relation(fields: [leadUuid], references: [uuid], onDelete: Cascade)
  actor User @relation(fields: [actorUuid], references: [uuid])

  @@index([leadUuid])
  @@index([actorUuid])
  @@map("lead_activities")
}

model NurtureEnrollment {
  uuid        String        @id @default(uuid())
  userUuid    String        @unique
  leadUuid    String        @unique
  status      NurtureStatus @default(ACTIVE)
  day1SentAt  DateTime?
  day3SentAt  DateTime?
  day7SentAt  DateTime?
  nextEmailAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  user User @relation(fields: [userUuid], references: [uuid])
  lead Lead @relation(fields: [leadUuid], references: [uuid])

  @@map("nurture_enrollments")
}

model LeadStatusLog {
  uuid          String      @id @default(uuid())
  leadUuid      String
  lead          Lead        @relation(fields: [leadUuid], references: [uuid], onDelete: Cascade)
  fromStatus    LeadStatus?
  toStatus      LeadStatus
  changedByUuid String?
  changedByRole String
  createdAt     DateTime    @default(now())

  @@index([leadUuid])
  @@index([changedByUuid])
  @@map("lead_status_logs")
}

// ─── Module 7: Task + Calendar Enums ─────────────────

enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETE
}

// ─── Module 6: Distributor Enums ─────────────────────

enum DistributorSubscriptionStatus {
  ACTIVE
  HALTED
  CANCELLED
  EXPIRED
  GRACE
}

// ─── Module 6: Distributor Models ────────────────────

model DistributorPlan {
  uuid           String                    @id @default(uuid())
  razorpayPlanId String                    @unique
  name           String
  amount         Float
  interval       String                    @default("monthly")
  isActive       Boolean                   @default(true)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  // Rich content fields for the subscription page
  tagline        String?
  features       String[]
  trustBadges    String[]
  ctaText        String?
  highlightBadge String?
  testimonials   Json     @default("[]")

  subscriptions       DistributorSubscription[]
  subscriptionHistory DistributorSubscriptionHistory[]

  @@map("distributor_plans")
}

model DistributorSubscription {
  uuid                   String                        @id @default(uuid())
  userUuid               String                        @unique
  planUuid               String
  razorpaySubscriptionId String                        @unique
  status                 DistributorSubscriptionStatus @default(ACTIVE)
  currentPeriodEnd       DateTime
  graceDeadline          DateTime?
  cancelledAt            DateTime?
  migrationPending       Boolean                       @default(false)
  planDeactivatedAt      DateTime?
  createdAt              DateTime                      @default(now())
  updatedAt              DateTime                      @updatedAt

  user User            @relation(fields: [userUuid], references: [uuid])
  plan DistributorPlan @relation(fields: [planUuid], references: [uuid])

  @@map("distributor_subscriptions")
}

model DistributorSubscriptionHistory {
  uuid                   String           @id @default(uuid())
  userUuid               String
  user                   User             @relation("DistributorSubscriptionHistory", fields: [userUuid], references: [uuid], onDelete: Cascade)
  planUuid               String?
  plan                   DistributorPlan? @relation(fields: [planUuid], references: [uuid])
  razorpaySubscriptionId String?
  event                  String
  amount                 Int?
  invoiceNumber          String?
  notes                  String?
  createdAt              DateTime         @default(now())

  @@index([userUuid])
  @@map("distributor_subscription_history")
}

// ─── Module 5: LMS Models ────────────────────────────

model Course {
  uuid             String    @id @default(uuid())
  title            String
  description      String
  thumbnailUrl     String?   @map("thumbnail_url")
  isFree           Boolean   @default(false) @map("is_free")
  price            Float     @default(0)
  isPublished      Boolean   @default(false) @map("is_published")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Rich landing page fields
  previewVideoUrl      String?   @map("preview_video_url")
  previewBunnyVideoId  String?   @map("preview_bunny_video_id")
  badge                String?
  instructors      String[]
  whatYouWillLearn String[]  @map("what_you_will_learn")
  originalPrice    Decimal?  @db.Decimal(10, 2) @map("original_price")
  totalDuration    String?   @map("total_duration")
  enrollmentBoost  Int       @default(0) @map("enrollment_boost")

  sections    CourseSection[]
  enrollments CourseEnrollment[]

  @@map("courses")
}

model CourseSection {
  uuid       String   @id @default(uuid())
  courseUuid String   @map("course_uuid")
  title      String
  order      Int
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  course  Course         @relation(fields: [courseUuid], references: [uuid], onDelete: Cascade)
  lessons CourseLesson[]

  @@map("course_sections")
}

model CourseLesson {
  uuid           String   @id @default(uuid())
  sectionUuid    String   @map("section_uuid")
  title          String
  description    String?
  videoUrl       String?  @map("video_url")
  bunnyVideoId   String?  @map("bunny_video_id")
  videoDuration  Int?     @map("video_duration") // in seconds
  textContent    String?  @map("text_content") // rich text
  pdfUrl         String?  @map("pdf_url")
  order          Int
  isPublished    Boolean  @default(false) @map("is_published")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Preview + attachment fields
  isPreview      Boolean  @default(false) @map("is_preview")
  attachmentUrl  String?  @map("attachment_url")
  attachmentName String?  @map("attachment_name")

  section  CourseSection    @relation(fields: [sectionUuid], references: [uuid], onDelete: Cascade)
  progress LessonProgress[]

  @@map("course_lessons")
}

model CourseEnrollment {
  uuid           String    @id @default(uuid())
  userUuid       String    @map("user_uuid")
  courseUuid     String    @map("course_uuid")
  enrolledAt     DateTime  @default(now()) @map("enrolled_at")
  completedAt    DateTime? @map("completed_at")
  certificateUrl String?   @map("certificate_url")
  isActive       Boolean   @default(true) @map("is_active")

  user   User   @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  course Course @relation(fields: [courseUuid], references: [uuid], onDelete: Cascade)

  @@unique([userUuid, courseUuid])
  @@map("course_enrollments")
}

model LessonProgress {
  uuid          String    @id @default(uuid())
  userUuid      String    @map("user_uuid")
  lessonUuid    String    @map("lesson_uuid")
  isCompleted   Boolean   @default(false) @map("is_completed")
  watchedSeconds Int      @default(0) @map("watched_seconds")
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user   User         @relation(fields: [userUuid], references: [uuid], onDelete: Cascade)
  lesson CourseLesson @relation(fields: [lessonUuid], references: [uuid], onDelete: Cascade)

  @@unique([userUuid, lessonUuid])
  @@map("lesson_progress")
}

// ─── Module 7: Task + Calendar Models ────────────────

model DistributorTask {
  uuid            String     @id @default(uuid())
  distributorUuid String
  leadUuid        String?
  title           String
  status          TaskStatus @default(TODO)
  dueDate         DateTime?
  order           Int        @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  distributor User  @relation("DistributorTasks", fields: [distributorUuid], references: [uuid])
  lead        Lead? @relation(fields: [leadUuid], references: [uuid])

  @@index([distributorUuid])
  @@map("distributor_tasks")
}

model DistributorCalendarNote {
  uuid            String   @id @default(uuid())
  distributorUuid String
  date            DateTime @db.Date
  note            String
  time            String?  // e.g. "14:30", "09:00" — optional, for ordering within a day
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  distributor User @relation("DistributorCalendarNotes", fields: [distributorUuid], references: [uuid])

  @@index([distributorUuid])
  @@map("distributor_calendar_notes")
}

// ─── Module 8: Campaign Models ────────────────────────

model Campaign {
  uuid        String   @id @default(uuid())
  ownerUuid   String
  ownerType   String   // "DISTRIBUTOR" | "ADMIN"
  name        String
  utmSource   String
  utmMedium   String
  utmCampaign String
  utmContent  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner User @relation(fields: [ownerUuid], references: [uuid], onDelete: Cascade)

  @@map("campaigns")
}

model BroadcastMessage {
  uuid          String   @id @default(uuid())
  type          String   // 'ANNOUNCEMENT' | 'BROADCAST'
  title         String
  shortMessage  String   // max 160 chars — shown in banner + bell dropdown
  fullContent   String?  // optional long content — shown on dedicated page
  link          String?  // optional URL — "Read more" redirects here if set
  targetRole    String?  // null=ALL, 'USER', 'CUSTOMER', 'DISTRIBUTOR'
  targetUuids   String[] // empty=all matching role, specific=selective
  createdByUuid String
  createdByRole String   // 'SUPER_ADMIN' | 'DISTRIBUTOR'
  isActive      Boolean  @default(true)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  reads         BroadcastRead[]

  @@index([createdByUuid])
  @@index([isActive])
  @@index([type])
  @@map("broadcast_messages")
}

model BroadcastRead {
  uuid          String           @id @default(uuid())
  broadcastUuid String
  broadcast     BroadcastMessage @relation(fields: [broadcastUuid], references: [uuid], onDelete: Cascade)
  userUuid      String
  createdAt     DateTime         @default(now())

  @@unique([broadcastUuid, userUuid])
  @@index([userUuid])
  @@map("broadcast_reads")
}

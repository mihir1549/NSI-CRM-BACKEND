# ────────────────────────────────────────────────────
# NSI Platform — Environment Variables
# Copy this file to .env and fill in your values
# ────────────────────────────────────────────────────

# App
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/nsi_db

# JWT
JWT_SECRET=your-super-secret-key-change-this-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Mail Provider — change this one value to switch provider
# Options: mock | resend
MAIL_PROVIDER=mock
MAIL_FROM=noreply@nageshwarshukla.com
MAIL_FROM_NAME=NSI Platform

# Resend (production — set when DNS is verified)
RESEND_API_KEY=re_xxxxxxxxxx

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# Twilio (phone verification)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_VERIFY_SERVICE_SID=VAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Razorpay (payments)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Provider modes — switch to real in production
# Options: mock | twilio
SMS_PROVIDER=mock
# Options: mock | razorpay
PAYMENT_PROVIDER=mock

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=nsi-platform
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Storage provider — Options: local | r2
STORAGE_PROVIDER=local
